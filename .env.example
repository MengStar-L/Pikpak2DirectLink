# Optional bootstrap credentials. The web UI can log in and persist the refresh token without these.
PIKPAK_USERNAME=
PIKPAK_PASSWORD=
ADDR=:51873
PUBLIC_BASE_URL=http://localhost:51873
# The access gate is always on. By default the FIRST visitor sets the admin
# password through the web UI; it is stored hashed (PBKDF2-SHA256) in ACCESS_AUTH_FILE.
# Set ACCESS_PASSWORD to pin a fixed password instead and skip the first-visitor setup.
# Proxy links use per-job tokens and remain accessible to downloaders without login.
ACCESS_PASSWORD=
ACCESS_AUTH_FILE=data/auth.json
PIKPAK_ROOT_FOLDER=Pikpak2DirectLink
PIKPAK_SESSION_FILE=data/pikpak-session.json
PIKPAK_ACCOUNTS_FILE=data/pikpak-accounts.json
PIKPAK_ACCOUNT_SESSION_DIR=data/accounts
PIKPAK_REQUEST_TIMEOUT=20s
RESOLVE_TIMEOUT=12m
POLL_INTERVAL=5s
# Link resolution is metered by a queue. RESOLVE_CONCURRENCY is the number of jobs
# resolved in parallel; 1 means serial (one at a time). This is only the INITIAL
# default — once an admin changes it on the Settings page the value is persisted in
# the database and that persisted value wins on the next start. Each job has a hard
# timeout: QUEUE_TIMEOUT while serial, PARALLEL_QUEUE_TIMEOUT while parallel (the
# longer budget reflects that parallel jobs share PikPak's attention).
RESOLVE_CONCURRENCY=1
QUEUE_TIMEOUT=45s
PARALLEL_QUEUE_TIMEOUT=2m
# Self-update settings. UPDATE_REPO is the GitHub "owner/name" checked for new
# releases; UPDATE_CHECK_INTERVAL is how often the server polls in the
# background (set to 0 to disable background checks; manual checks still work).
UPDATE_REPO=MengStar-L/Pikpak2DirectLink
UPDATE_CHECK_INTERVAL=6h
